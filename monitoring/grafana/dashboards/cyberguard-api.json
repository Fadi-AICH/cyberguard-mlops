        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "content": "## CyberGuard CICIoT2023 SOC Command Center\nReal CICIoT2023 IoT intrusion scoring with country enrichment, server flows, severity distribution, attacker ranking, API health, and latency monitoring.",
        "mode": "markdown"
      },
      "title": "",
      "type": "text"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 3 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "up{job=\"cyberguard-api\"}", "legendFormat": "api", "refId": "A" }],
      "title": "API Health",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 3 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "cyberguard_predictions_total", "legendFormat": "predictions", "refId": "A" }],
      "title": "Total Predictions",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 50 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 3 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "cyberguard_predicted_attacks_total", "legendFormat": "alerts", "refId": "A" }],
      "title": "Predicted Attack Alerts",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 20 }, { "color": "red", "value": 45 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 3 },
      "id": 5,
      "options": { "displayMode": "lcd", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "valueMode": "color" },
      "targets": [{ "expr": "100 * cyberguard_predicted_attacks_total / clamp_min(cyberguard_predictions_total, 1)", "legendFormat": "attack ratio", "refId": "A" }],
      "title": "Attack Ratio",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "decimals": 3,
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.25 }, { "color": "red", "value": 0.6 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 3 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(cyberguard_prediction_latency_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p95", "refId": "A" }],
      "title": "Latency p95",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "rate(cyberguard_predictions_total[$__rate_interval])", "legendFormat": "prediction traffic", "refId": "A" },
        { "expr": "rate(cyberguard_predicted_attacks_total[$__rate_interval])", "legendFormat": "attack alerts", "refId": "B" }
      ],
      "title": "Prediction Traffic vs Attack Alerts",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 8,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(cyberguard_prediction_latency_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.90, sum(rate(cyberguard_prediction_latency_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p90", "refId": "B" },
        { "expr": "histogram_quantile(0.95, sum(rate(cyberguard_prediction_latency_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p95", "refId": "C" }
      ],
      "title": "Latency Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 9,
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [{ "expr": "sum by (severity) (cyberguard_predictions_by_context_total)", "legendFormat": "{{severity}}", "refId": "A" }],
      "title": "Severity Levels",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 30 }] } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 10,
      "options": { "displayMode": "gradient", "namePlacement": "left", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "valueMode": "color" },
      "targets": [{ "expr": "topk(10, sum by (country) (cyberguard_predicted_attacks_by_context_total))", "legendFormat": "{{country}}", "refId": "A" }],
      "title": "Top Attacker Source Countries",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 11,
      "options": {
        "basemap": { "config": {}, "name": "Layer 0", "type": "default" },
        "controls": { "mouseWheelZoom": true, "showAttribution": false, "showDebug": false, "showMeasure": false, "showScale": true, "showZoom": true },
        "layers": [
          {
            "config": {
              "showLegend": true,
              "style": { "color": { "fixed": "dark-red" }, "opacity": 0.75, "size": { "fixed": 12, "max": 40, "min": 6 } }
            },
            "location": { "lookup": "country", "mode": "lookup" },
            "name": "Attack countries",
            "tooltip": true,
            "type": "markers"
          }
        ],
        "view": { "id": "world" }
      },
      "targets": [{ "expr": "sum by (country) (cyberguard_predicted_attacks_by_context_total)", "format": "table", "legendFormat": "{{country}}", "refId": "A" }],
      "title": "World Attack Map",
      "type": "geomap"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 23 },
      "id": 12,
      "options": { "showHeader": true },
      "targets": [{ "expr": "topk(12, sum by (country, server, severity) (cyberguard_predicted_attacks_by_context_total))", "format": "table", "legendFormat": "{{country}} -> {{server}}", "refId": "A" }],
      "title": "Country / Server Flow Matrix",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 16, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 23 },
      "id": 13,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"cyberguard-api\"}", "legendFormat": "Resident memory", "refId": "A" },
        { "expr": "rate(process_cpu_seconds_total{job=\"cyberguard-api\"}[$__rate_interval])", "legendFormat": "CPU seconds/sec", "refId": "B" }
      ],
      "title": "API Runtime Footprint",
      "type": "timeseries"
    }
  ],
